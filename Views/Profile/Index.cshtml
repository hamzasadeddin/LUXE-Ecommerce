@model LuxeEcommerce.Models.User
@{
    ViewBag.Title = "My Profile";
}

<div style="padding:3rem 0 5rem;">
    <div class="container" style="max-width:800px;">
        <div class="d-flex align-items-center gap-4 mb-4">
            <img src="@Model.AvatarUrl" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--clr-gold);" />
            <div>
                <span class="section-label">My Account</span>
                <h1 style="font-family:var(--font-display);font-size:2rem;margin:.25rem 0;">@Model.FullName</h1>
                <p style="color:var(--clr-text-muted);font-size:.875rem;">Member since @Model.MemberSince</p>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div style="background:var(--clr-surface);border:1px solid var(--clr-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                    <i class="fas fa-shopping-bag" style="font-size:1.5rem;color:var(--clr-gold);margin-bottom:.75rem;"></i>
                    <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;">12</div>
                    <div style="font-size:.8rem;color:var(--clr-text-muted);">Total Orders</div>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:var(--clr-surface);border:1px solid var(--clr-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                    <i class="far fa-heart" style="font-size:1.5rem;color:var(--clr-gold);margin-bottom:.75rem;"></i>
                    <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;">7</div>
                    <div style="font-size:.8rem;color:var(--clr-text-muted);">Wishlist Items</div>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:var(--clr-surface);border:1px solid var(--clr-border);border-radius:var(--radius-lg);padding:1.5rem;text-align:center;">
                    <i class="fas fa-star" style="font-size:1.5rem;color:var(--clr-gold);margin-bottom:.75rem;"></i>
                    <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;">Gold</div>
                    <div style="font-size:.8rem;color:var(--clr-text-muted);">Member Tier</div>
                </div>
            </div>
        </div>

        <div class="order-summary-box">
            <h5 style="font-family:var(--font-display);font-size:1rem;margin-bottom:1.5rem;">Account Details</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label-luxe">Full Name</label>
                    <input class="form-control-luxe" value="@Model.FullName" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label-luxe">Email Address</label>
                    <input class="form-control-luxe" value="@Model.Email" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label-luxe">Phone</label>
                    <input class="form-control-luxe" value="@(Model.Phone ?? "Not provided")" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label-luxe">Member Since</label>
                    <input class="form-control-luxe" value="@Model.MemberSince" readonly />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn-luxe-outline" onclick="showToast('Edit mode coming soon!','ℹ️')">Edit Profile</button>
                <a href="@Url.Action("Logout", "Account")" class="btn-luxe-outline" style="color:red;border-color:red;">Sign Out</a>
            </div>
        </div>
    </div>
</div>