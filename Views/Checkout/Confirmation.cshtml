@model LuxeEcommerce.Models.Order
@{
    ViewBag.Title = "Order Confirmed";
}

<div style="padding:5rem 0;min-height:70vh;">
    <div class="container" style="max-width:680px;">
        <div class="text-center">
            <div class="confirmation-icon">✓</div>
            <span class="section-label">Thank You!</span>
            <h1 style="font-family:var(--font-display);font-size:2.5rem;margin:.5rem 0;">Order Confirmed</h1>
            <p style="color:var(--clr-text-muted);">Your order has been placed successfully. A confirmation has been sent to your email.</p>
        </div>

        <div class="order-summary-box mt-4">
            <div class="d-flex justify-content-between mb-3">
                <div>
                    <div class="section-label">Order Number</div>
                    <div style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;">@Model.OrderNumber</div>
                </div>
                <div class="text-end">
                    <div class="section-label">Date</div>
                    <div style="font-size:.9rem;">@Model.OrderDate.ToString("MMMM dd, yyyy")</div>
                </div>
            </div>
            <div class="divider-gold"></div>

            @foreach (var item in Model.Items)
            {
                <div class="d-flex gap-3 mb-2 mt-2">
                    <img src="@item.ImageUrl" style="width:55px;height:70px;object-fit:cover;border-radius:var(--radius);" />
                    <div style="flex:1;">
                        <div style="font-weight:600;font-size:.875rem;">@item.ProductName</div>
                        <div style="font-size:.8rem;color:var(--clr-text-muted);">Qty @item.Quantity</div>
                    </div>
                    <div style="font-weight:600;">$@item.Subtotal.ToString("F2")</div>
                </div>
            }

            <div style="border-top:1px solid var(--clr-border);margin-top:1rem;padding-top:1rem;">
                <div class="order-summary-row"><span>Subtotal</span><span>$@Model.Subtotal.ToString("F2")</span></div>
                <div class="order-summary-row"><span>Shipping</span><span>@(Model.Shipping == 0 ? "Free" : "$" + Model.Shipping.ToString("F2"))</span></div>
                <div class="order-summary-row"><span>Tax</span><span>$@Model.Tax.ToString("F2")</span></div>
                <div class="order-summary-row order-summary-total"><span>Total</span><span>$@Model.Total.ToString("F2")</span></div>
            </div>
        </div>

        <div class="text-center mt-4 d-flex gap-3 justify-content-center">
            <a href="@Url.Action("Index", "Home")" class="btn-luxe">Back to Home</a>
            <a href="@Url.Action("Index", "Shop")" class="btn-luxe-outline">Continue Shopping</a>
        </div>
    </div>
</div>