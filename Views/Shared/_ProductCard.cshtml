@model LuxeEcommerce.Models.Product

<div class="product-card h-100">
    <div class="product-card-image">
        <img src="@Model.ImageUrl" alt="@Model.Name" loading="lazy" />
        @if (Model.IsNew)
        {
            <span class="product-badge badge-new">New</span>
        }
        @if (Model.DiscountPercent.HasValue)
        {
            <span class="product-badge badge-sale" style="top:40px;">-@Model.DiscountPercent%</span>
        }
        <div class="product-card-actions">
            <button class="product-action-btn" onclick="addToCart(@Model.Id)" title="Add to Bag">
                <i class="fas fa-shopping-bag"></i>
            </button>
            <a href="@Url.Action("Detail", "Shop", new { id = Model.Id })" class="product-action-btn" title="View Details">
                <i class="far fa-eye"></i>
            </a>
            <button class="product-action-btn" onclick="toggleWishlist(this)" title="Wishlist">
                <i class="far fa-heart"></i>
            </button>
        </div>
    </div>
    <div class="product-card-body">
        <div class="product-brand">@Model.Brand</div>
        <div class="product-name">
            <a href="@Url.Action("Detail", "Shop", new { id = Model.Id })" style="text-decoration:none;color:inherit;">@Model.Name</a>
        </div>
        <div class="d-flex align-items-center gap-1 mb-1">
            <span class="star-rating">@(new string('★', (int)Model.Rating))@(Model.Rating % 1 >= 0.5 ? "½" : "")</span>
            <span class="rating-count">(@Model.ReviewCount)</span>
        </div>
        <div class="product-price">
            <span class="price-current">$@Model.Price.ToString("F2")</span>
            @if (Model.OriginalPrice.HasValue)
            {
                <span class="price-original">$@Model.OriginalPrice.Value.ToString("F2")</span>
            }
        </div>
    </div>
</div>