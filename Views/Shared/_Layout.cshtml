@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "LUXE") — Refined Fashion</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/luxe-styles.css" asp-append-version="true" />
</head>
<body>


    <div class="promo-banner">
        Free shipping on orders over <span>$200</span> &nbsp;|&nbsp; New arrivals every week
    </div>


    <nav class="luxe-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand-text" asp-controller="Home" asp-action="Index">LUXE<span>.</span></a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Shop" asp-action="Index">Shop</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Shop" asp-action="Index" asp-route-category="Women">Women</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Shop" asp-action="Index" asp-route-category="Men">Men</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Shop" asp-action="Index" asp-route-category="Accessories">Accessories</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <a asp-controller="Profile" asp-action="Index" class="navbar-icon-btn" title="Account">
                            <i class="far fa-user"></i>
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="navbar-icon-btn" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="navbar-icon-btn" title="Login">
                            <i class="far fa-user"></i>
                        </a>
                    }
                    <a asp-controller="Cart" asp-action="Index" class="navbar-icon-btn" title="Cart" style="position:relative;">
                        <i class="fas fa-shopping-bag"></i>
                        <span id="cart-badge" class="cart-badge" style="display:none;">0</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="luxe-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-brand">LUXE<span>.</span></div>
                    <p style="font-size:.875rem; max-width:300px;">
                        Curated fashion for those who appreciate quality, craftsmanship, and timeless style.
                    </p>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Shop</div>
                    <a asp-controller="Shop" asp-action="Index" asp-route-category="Women" class="footer-link">Women</a>
                    <a asp-controller="Shop" asp-action="Index" asp-route-category="Men" class="footer-link">Men</a>
                    <a asp-controller="Shop" asp-action="Index" asp-route-category="Accessories" class="footer-link">Accessories</a>
                    <a asp-controller="Shop" asp-action="Index" asp-route-sort="newest" class="footer-link">New Arrivals</a>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Help</div>
                    <a href="#" class="footer-link">Shipping</a>
                    <a href="#" class="footer-link">Returns</a>
                    <a href="#" class="footer-link">Size Guide</a>
                    <a href="#" class="footer-link">Contact Us</a>
                </div>
                <div class="col-lg-4">
                    <div class="footer-heading">Newsletter</div>
                    <p style="font-size:.875rem; margin-bottom:1rem;">
                        Subscribe for early access to new arrivals and exclusive offers.
                    </p>
                    <div class="d-flex gap-2">
                        <input type="email" class="form-control-luxe" placeholder="your@email.com" style="flex:1;" />
                        <button class="btn-luxe-gold" onclick="showToast('Subscribed! 🎉')">Join</button>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year LUXE. All rights reserved.</span>
                <div class="d-flex gap-3">
                    <a href="#" class="footer-link" style="font-size:.75rem;">Privacy Policy</a>
                    <a href="#" class="footer-link" style="font-size:.75rem;">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/luxe-app.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>